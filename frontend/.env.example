# Secret usado por NextAuth para firmar/encriptar la sesión JWT (src/lib/auth.ts)
# Generar uno con: openssl rand -base64 32
NEXTAUTH_SECRET="reemplazar-por-un-secreto-largo-y-aleatorio"

# URL pública de la app; NextAuth la necesita para construir callbacks correctamente
NEXTAUTH_URL="http://localhost:3000"

# URL del backend Express al que el frontend le pide login/registro/datos.
# En producción, la URL pública del backend desplegado (Railway/Render).
NEXT_PUBLIC_API_URL="http://localhost:3001"
