# URL de conexión a PostgreSQL, usada por Prisma
DATABASE_URL="postgresql://usuario:password@localhost:5432/kumelen"

# Secret para firmar los JWT de autenticación (backend/middlewares/authMiddleware.js, backend/controllers/authController.js)
# Generar uno con: openssl rand -base64 32
JWT_SECRET="reemplazar-por-un-secreto-largo-y-aleatorio"

# Tiempo de expiración del JWT (backend/controllers/authController.js). Ej: 1d, 12h, 7d
JWT_EXPIRES_IN="1d"

# Puerto del servidor Express (opcional, default 3001)
PORT=3001
